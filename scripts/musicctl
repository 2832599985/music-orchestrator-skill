#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="${BASE_DIR}/.venv"

if [ ! -x "${VENV_DIR}/bin/python" ]; then
  echo "music-orchestrator dependencies are not installed. Run: ${BASE_DIR}/scripts/install.sh" >&2
  exit 1
fi

exec "${VENV_DIR}/bin/python" "${BASE_DIR}/scripts/music_orchestrator.py" "$@"
